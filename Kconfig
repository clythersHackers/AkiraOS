menu "Peripherals"

config CHARGER_BQ25601
    bool "Enable BQ25601 Li-Ion charger driver"
    default y if DT_HAS_TI_BQ25601_ENABLED
    depends on I2C && CHARGER
    help
      Enable TI BQ25601RTW Li-Ion battery charger driver.
      Implements the Zephyr charger API.
      Reports charge status, VBUS presence, faults.
      Allows setting charge current (0–3000 mA) and voltage (3840–4608 mV).


config FUEL_GAUGE_BQ28Z610
    bool "Enable BQ28Z610 fuel gauge driver"
    default y if DT_HAS_TI_BQ28Z610_ENABLED
    depends on I2C && FUEL_GAUGE
    help
      Enable TI BQ28Z610DRZ 1-cell Li-Ion fuel gauge + protection driver.
      Implements the Zephyr fuel_gauge API over I2C (SBS-compatible registers).
      Reports SoC, voltage, current, temperature, remaining/full capacity,
      time-to-empty, and cycle count.
config AKIRA_PWM_DIAL
    bool "Enable generic PWM-dial rotary input driver"
    default y if DT_HAS_AKIRA_PWM_DIAL_ENABLED
    depends on PWM && INPUT
    help
      Enable the akira,pwm-dial driver.  Reads the duty cycle of a
      potentiometer-based RC oscillator via MCPWM capture and reports
      INPUT_ABS_WHEEL (0-255) into the Zephyr input subsystem.
      On AkiraConsole Production: RK10J12R0A0B (RV1) on GPIO48.

config AKIRA_ST25DV
    bool "Enable ST25DV64K NFC tag driver"
    default y if DT_HAS_ST_ST25DV64K_ENABLED
    depends on I2C
    help
      Enable STMicroelectronics ST25DV64K Dynamic NFC/RFID tag driver.
      Provides I2C access to the 64 Kbit EEPROM user memory and system
      configuration registers. GPO interrupt for RF field / write events.
      RF operations (ISO 15693) happen autonomously when an NFC reader
      is present.

endmenu

menu "Connectivity"

config AKIRA_USB
    bool "Enable Akira USB Manager"
    default n
    select USB_DEVICE_STACK_NEXT
    select UDC_DRIVER
    help
      Enable Akira USB Manager for MASS and USB HID

config AKIRA_USB_CDC_SERIAL
    bool "Enable USB CDC serial JSON-RPC transport"
    default n
    depends on AKIRA_USB && USB_CDC_ACM
    select BASE64
    help
      Expose the AkiraOS management API over a USB CDC ACM virtual COM port
      using newline-delimited JSON-RPC 2.0.  Allows a browser running the
      hosted web UI (e.g. lab.akiraos.io) to manage the device over USB
      via the Web Serial API without requiring WiFi connectivity.

      Requires CONFIG_USB_CDC_ACM=y and a DT chosen node
      zephyr,cdc-acm-uart pointing to the CDC UART instance.

config AKIRA_USB_CDC_SERIAL_STACK_SIZE
    int "CDC serial RX thread stack size (bytes)"
    default 2048
    depends on AKIRA_USB_CDC_SERIAL
    help
      Stack size for the JSON-RPC reader thread.
      Increase if handler callbacks perform deep call chains.

config AKIRA_USB_CDC_SERIAL_RX_BUF_SIZE
    int "CDC serial RX ring buffer size (bytes)"
    default 2048
    range 512 8192
    depends on AKIRA_USB_CDC_SERIAL
    help
      Size of the ring buffer that holds bytes received from the USB host
      before the reader thread can process them.

config AKIRA_USB_CDC_SERIAL_TX_BUF_SIZE
    int "CDC serial TX ring buffer size (bytes)"
    default 4096
    range 1024 16384
    depends on AKIRA_USB_CDC_SERIAL
    help
      Size of the ring buffer that queues outgoing JSON-RPC responses and
      event notifications on their way to the USB host.

config AKIRA_MODULE_WIFI
    bool "Enable Akira Connectivity module (WiFi/BLE/Cloud)"
    default n
    help
      Enable higher-level connectivity providers (WiFi, BLE, Cloud).

config AKIRA_HID
