# ---------------------------------------------------------------------------
# SD Card Hardware
# ---------------------------------------------------------------------------
menu "SD Card"

config AKIRA_SD_CARD
    bool "Enable SD card hardware support"
    default n
    select DISK_ACCESS
    select FAT_FILESYSTEM_ELM
    help
      Enables the SD card hardware driver (sd_card.c) which probes the disk
      and mounts FATFS at /SD: via SYS_INIT at CONFIG_AKIRA_SD_INIT_PRIORITY.

      The actual hardware interface (SPI-SDHC or native SDMMC) is selected
      by each board's .conf and .overlay files independently of this option.

      Enable per-board:
        CONFIG_SDHC=y
        CONFIG_DISK_DRIVER_SDHC=y     # SPI-based, most boards
        # or
        CONFIG_DISK_DRIVER_SDMMC=y    # native SDMMC peripheral

config AKIRA_SD_INIT_PRIORITY
    int "SD card SYS_INIT priority"
    default 38
    depends on AKIRA_SD_CARD
    help
      Automatic init priority for the SD card driver.  Must be lower than
      AKIRA_FS_INIT_PRIORITY (default 40) so the SD mount is complete before
      fs_manager queries disk availability.

endmenu # SD Card

