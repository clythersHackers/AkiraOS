config AKIRA_SANDBOX_EXEC_TIMEOUT_MS
    int "WASM execution timeout (ms)"
    default 5000
    range 1000 30000
    depends on AKIRA_SANDBOX
    help
      Maximum execution time for a single WASM function call before
      the watchdog kills the app. Set higher for compute-heavy apps.

config AKIRA_WASM_START_TIMEOUT_MS
    int "WASM instantiation timeout (ms)"
    default 15000
    range 2000 60000
    depends on AKIRA_WASM_RUNTIME
    help
      Maximum time to wait for a WASM module to complete instantiation
      and signal readiness. Increase if modules perform heavy init work.

config AKIRA_WASM_STOP_TIMEOUT_MS
    int "WASM stop/join timeout (ms)"
    default 5000
    range 1000 30000
    depends on AKIRA_WASM_RUNTIME
    help
      Maximum time to wait for a WASM app thread to exit cleanly after
      wasm_runtime_terminate() is called. Thread is aborted on timeout.

config AKIRA_BOOT_DELAY_MS
    int "Boot splash delay (ms)"
    default 3000
    range 0 10000
    depends on AKIRA_DISPLAY
    help
      How long to show the boot splash screen before continuing
      with system initialisation. Set to 0 to disable the delay.

config AKIRA_SANDBOX_RATE_LIMITING
    bool "Enable syscall rate limiting"
    default y
    depends on AKIRA_SANDBOX
    help
      Enable per-category rate limiting for syscalls.
      Prevents apps from hogging hardware resources.

config AKIRA_SECURITY_AUDIT
    bool "Enable security audit logging"
    default y
    depends on AKIRA_CAPABILITY_SYSTEM
    help
      Enable ring buffer security audit log that records
      denied capabilities, rate limits, and watchdog kills.

config AKIRA_AUDIT_LOG_SIZE
    int "Audit log entries"
    default 32
    range 16 128
    depends on AKIRA_SECURITY_AUDIT
    help
      Number of audit log entries in the ring buffer.
      Each entry uses ~68 bytes of RAM.

config AKIRA_WASM_INTEGRITY_CHECK
    bool "Enable WASM binary integrity verification"
    default y
    depends on AKIRA_CAPABILITY_SYSTEM
    help
      Verify WASM binary structural integrity (magic, version,
      section layout) before loading. Catches corrupted binaries.

config AKIRA_MODULE_CACHE
    bool "Enable WASM module cache"
    default y
    depends on AKIRA_WASM_RUNTIME
    help
      Cache loaded WASM modules by SHA-256 hash to avoid
      reloading identical binaries. Trades RAM for performance.

config AKIRA_MODULE_CACHE_SIZE
    int "Module cache entries"
    default 4
    range 2 8
    depends on AKIRA_MODULE_CACHE
    help
      Maximum number of cached WASM modules.
      Each cached module retains the parsed WAMR module in memory.

endmenu

