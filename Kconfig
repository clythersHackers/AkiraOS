      and named action hotkey functions to WASM applications.
      Requires AKIRA_CAP_HID capability in the app manifest.
      Do NOT enable on native_sim (no BT/USB HID transport).

config AKIRA_HID_MAX_ACTIONS
    int "Maximum named HID action bindings"
    default 8
    range 1 64
    depends on AKIRA_WASM_HID
    help
      Size of the static named-action registry used by
      hid_action_register() / hid_action_trigger().
      Each entry uses ~34 bytes of SRAM.

config AKIRA_INPUT_API
    bool "Enable AkiraConsole button input native API"
    default n
    depends on INPUT
    help
      Registers an INPUT_CALLBACK_DEFINE handler that maintains an atomic
      bitmask of currently held buttons and a 16-entry ring buffer of
      press/release edge events from the gpio-keys DTS node.
      Required for CONFIG_AKIRA_WASM_INPUT.

config AKIRA_WASM_INPUT
    bool "Export button Input API to WASM"
    default n
    depends on AKIRA_WASM_API && AKIRA_INPUT_API
    help
      Export input_get_buttons() and input_poll_event() to WASM applications.
      input_get_buttons() returns a uint32 bitmask of currently held buttons
      (bit N = 1 << zephyr,code).  input_poll_event() drains one edge event
      from the ring buffer.  Requires "input.read" capability in the manifest.

config AKIRA_SYSTEM_API
    bool "Enable privileged system-level native API"
    default n
    depends on AKIRA_WASM_RUNTIME && AKIRA_SD_CARD
    help
      Exposes sd_scan_wasm() — lists *.wasm files under /SD:/apps/ into a
      WASM buffer.  Requires "app.control" elevated capability.

config AKIRA_BOOT_SHELL
    bool "Auto-launch a WASM shell app at boot"
    default n
    depends on AKIRA_APP_MANAGER
    help
      If enabled, main() calls app_manager_start(CONFIG_AKIRA_BOOT_SHELL_NAME)
      immediately after app_manager_init().  If the named app is not installed
      a warning is logged and boot continues normally.

config AKIRA_BOOT_SHELL_NAME
    string "Name of WASM shell app to auto-launch"
    default "akira_shell"
    depends on AKIRA_BOOT_SHELL
    help
      Must match the "name" field in the app's manifest.json exactly.

config AKIRA_BOOT_SHELL_RESTART
    bool "Auto-restart shell on exit or crash"
    default y
    depends on AKIRA_BOOT_SHELL
    help
      When enabled, the firmware idle loop detects that no WASM app is
      running and re-launches CONFIG_AKIRA_BOOT_SHELL_NAME after a
      1.5 s cooldown.  This makes the shell behave like a firmware
      component: any app exit or crash return the user to the shell.

config AKIRA_OS_SHELL
    bool "Enable AkiraConsole native OS shell"
    default n
    depends on DISPLAY
    select AKIRA_APP_MANAGER
    help
      Enables the native C OS shell that replaces the WASM akira_shell app.
      Uses the akira_display_* framebuffer API directly — no LVGL required.
      Provides an app launcher, SD card install, BLE install, and a full
      settings panel.  Mutually exclusive with CONFIG_AKIRA_BOOT_SHELL —
      disable that option when enabling this one.

config AKIRA_OS_SHELL_SCREEN_W
    int "OS shell screen width in pixels"
    default 320
    range 240 800
    depends on AKIRA_OS_SHELL
    help
      Pixel width of the display used by the native OS shell.
      Set to 400 for the Sharp LS027B7DH01 (AkiraConsole Production),
      320 for the ST7789V / ILI9341 TFT variants.

config AKIRA_HOME_BUTTON_GPIO
    int "GPIO pin number for the HOME / X button"
    default 17
    depends on AKIRA_OS_SHELL && GPIO
    help
      GPIO pin wired to the HOME (X) button on AkiraConsole.  A long press
      (longer than CONFIG_AKIRA_HOME_BUTTON_GPIO_LONG_MS) dismisses any
      running WASM app and returns to the OS shell launcher.

config AKIRA_HOME_BUTTON_GPIO_LONG_MS
    int "Long-press duration threshold for HOME button (ms)"
    default 500
    depends on AKIRA_OS_SHELL
    help
      How long the HOME button must be held before the OS shell intercepts
      the press and returns to the launcher.  Shorter presses are passed
      through to the active WASM app as a normal key event.

config AKIRA_OS_VERSION
    string "AkiraOS version string"
    default "1.0.0"
    help
      Human-readable version string displayed in the OS shell settings
      screen and included in OTA manifests.

config AKIRA_WASM_SETTINGS
    bool "Export persistent settings API to WASM"
    default n
    depends on AKIRA_WASM_API && AKIRA_SETTINGS
    help
      Exports settings_get / settings_set to WASM apps so they can
      store and retrieve persistent key-value pairs in NVS flash.
      Requires the \"settings.*\" capability in the app manifest.

config AKIRA_WASM_LIFECYCLE
    bool "Export App Lifecycle API to WASM"
    default n
    depends on AKIRA_WASM_API && AKIRA_APP_MANAGER
    help
      Export app_start / app_stop / app_restart / app_get_status /
      app_list / app_get_self_name to WASM applications.
      Requires AKIRA_CAP_APP_CONTROL — elevated privilege; must NOT be
      granted to untrusted apps by default.

config AKIRA_WASM_IPC
    bool "Export Inter-App Messaging API to WASM"
    default n
    depends on AKIRA_WASM_API
    help
      Export named-topic pub/sub IPC to WASM applications.
      Apps subscribe to topics, publish messages, and receive messages
      from other apps.  Requires AKIRA_CAP_IPC capability.
      msgq backing buffers are allocated from PSRAM when available.

config AKIRA_IPC_MAX_TOPICS
    int "Maximum number of IPC topics"
    default 8
    range 1 32
    depends on AKIRA_WASM_IPC
    help
      Maximum number of simultaneously active named IPC topics.
      Default raised to 8 to accommodate the built-in akira.lifecycle topic
      plus additional user topics.

config AKIRA_IPC_MAX_SUBS_PER_TOPIC
    int "Maximum subscribers per IPC topic"
    default 4
    range 1 16
    depends on AKIRA_WASM_IPC
    help
      Maximum number of apps that can subscribe to one topic.
      Default raised to 4 so supervisor plus multiple concurrent apps can
      all subscribe to akira.lifecycle simultaneously.

config AKIRA_IPC_MSG_MAX_SIZE
    int "Maximum IPC message payload size (bytes)"
    default 64
    range 16 1024
    depends on AKIRA_WASM_IPC
    help
      Maximum size of a single IPC message payload in bytes.
      Each subscriber queue slot uses this much PSRAM/SRAM.

config AKIRA_IPC_QUEUE_DEPTH
    int "IPC subscriber queue depth (messages)"
    default 2
    range 1 16
    depends on AKIRA_WASM_IPC
    help
      Number of messages each subscriber queue can hold before
      dropping new messages from publishers.

config AKIRA_WASM_TIMER
    bool "Export Timer API to WASM"
    default y
    depends on AKIRA_WASM_API
    help
      Export polling timer functions to WASM applications.
      Provides timer_create/start/stop/elapsed/free backed by k_uptime_get().
      Requires AKIRA_CAP_TIMER capability in the app manifest.

config AKIRA_WASM_TIMER_MAX_HANDLES
    int "Maximum number of concurrent WASM timer handles"
    default 8
    range 1 32
    depends on AKIRA_WASM_TIMER
    help
      Maximum number of simultaneously active timer handles across all WASM apps.
      Each handle uses ~20 bytes of static RAM.

config AKIRA_WASM_UART
    bool "Export UART API to WASM"
    default n
    depends on AKIRA_WASM_API && SERIAL
    help
      Export UART read/write functions to WASM applications.
      UART0 (shell/log) is reserved; WASM apps access UART1+.
      Requires AKIRA_CAP_UART capability in the app manifest.

config AKIRA_WASM_UART_RX_BUF_SIZE
    int "WASM UART RX ring buffer size (bytes)"
    default 256
    range 64 4096
    depends on AKIRA_WASM_UART
    help
      Size of the per-handle IRQ-driven RX ring buffer.
      Bytes received via UART interrupt are stored here until
      the WASM app calls uart_read().

config AKIRA_WASM_I2C
    bool "Export I2C API to WASM"
    default n
    depends on AKIRA_WASM_API && I2C
    help
      Export raw I2C register read/write functions to WASM applications.
      Stateless API: WASM passes bus_id + device address + register per call.
      Requires AKIRA_CAP_I2C capability in the app manifest.

config AKIRA_WASM_PWM
    bool "Export PWM API to WASM"
    default n
    depends on AKIRA_WASM_API && PWM
    help
      Export PWM channel control to WASM applications.
      Provides pwm_set(channel, freq_hz, duty_pct) and pwm_disable(channel).
      Requires AKIRA_CAP_PWM capability in the app manifest.

config AKIRA_WASM_ADC
    bool "Export ADC API to WASM"
    default n
    depends on AKIRA_WASM_API && ADC
    help
      Export ADC channel read functions to WASM applications.
      Provides adc_read(channel) and adc_read_mv(channel).
      Board overlay must enable the ADC node and set alias akira-adc pointing
      to it.  If the alias is absent the first zephyr,adc device is used.
      Requires AKIRA_CAP_ADC capability ("adc") in the app manifest.

config AKIRA_WASM_ADC_MAX_CHANNELS
    int "Maximum ADC channels exposed to WASM"
    default 4
    range 1 16
    depends on AKIRA_WASM_ADC
    help
      Upper bound on the channel index accepted by adc_read() / adc_read_mv().
      Channels are lazily configured on first access.

config AKIRA_WASM_ADC_RESOLUTION
    int "ADC resolution in bits"
    default 12
    range 8 16
    depends on AKIRA_WASM_ADC
    help
      Bit resolution passed to the Zephyr ADC driver for each conversion.
      Must match the hardware capability of the selected ADC device.

config AKIRA_WASM_ADC_VREF_MV
    int "ADC reference voltage in millivolts"
    default 3300
    range 1000 5000
    depends on AKIRA_WASM_ADC
    help
      Reference voltage used by adc_read_mv() for raw-to-millivolt conversion.
      Set to the board's actual VREF (e.g. 3300 for 3.3 V, 1800 for 1.8 V).

config AKIRA_WDT
    bool "AkiraOS system watchdog"
    default n
    depends on WATCHDOG
    help
      Enable hardware watchdog timer integration for AkiraOS.
      The first enabled zephyr,watchdog device found in the device tree is
      used — no additional board-specific code is required.
      A background worker auto-feeds the WDT every AKIRA_WDT_FEED_INTERVAL_MS
      so the system resets only if AkiraOS itself hangs.
      Board overlay must enable the watchdog node (status = "okay").
      Board .conf must set CONFIG_WATCHDOG=y and CONFIG_AKIRA_WDT=y.

config AKIRA_WDT_TIMEOUT_MS
    int "Watchdog timeout in milliseconds"
    default 30000
    range 1000 120000
    depends on AKIRA_WDT
    help
      Hardware watchdog timeout.  The system resets if the WDT is not fed
      within this window.  Must be greater than AKIRA_WDT_FEED_INTERVAL_MS.

config AKIRA_WDT_FEED_INTERVAL_MS
    int "Watchdog auto-feed interval in milliseconds"
    default 10000
    range 500 60000
    depends on AKIRA_WDT
    help
      Interval at which the AkiraOS WDT worker automatically feeds the
      watchdog.  Must be less than AKIRA_WDT_TIMEOUT_MS.

config AKIRA_WASM_WDT
    bool "Export WDT pet API to WASM"
    default n
    depends on AKIRA_WASM_API && AKIRA_WDT
    help
      Allows WASM apps to manually pet/feed the system watchdog via wdt_pet().
      Useful for apps that want to signal liveness to the hardware watchdog.
      Requires AKIRA_CAP_WDT capability ("wdt") in the app manifest.

config AKIRA_WASM_STORAGE
    bool "Export Storage (filesystem) API to WASM"
    default y
    depends on AKIRA_WASM_API && FILE_SYSTEM
    help
      Export sandboxed file I/O to WASM applications.

      Each app is confined to <best_mount>/apps/<app_name>/ where best_mount
      is SD card if present, then LittleFS, then RAM.  Path traversal (..) is
      rejected with -EACCES.

      Required capabilities in the app manifest:
        "storage.read"  — read / list
        "storage.write" — write / delete

config AKIRA_WASM_STORAGE_MAX_FDS
    int "Maximum simultaneous open storage files per-system"
    default 8
    range 2 32
    depends on AKIRA_WASM_STORAGE
    help
      Global limit on open storage file descriptors across all running WASM
      apps.  Each descriptor holds a Zephyr struct fs_file_t (~48 bytes).

config AKIRA_WASM_FS
    bool "Export rich POSIX-like filesystem API to WASM"
    default n
    depends on AKIRA_WASM_API && FILE_SYSTEM
    help
      POSIX-like filesystem surface for WASM apps: fs_open/close/read/write/
      seek/tell/stat/unlink/mkdir/readdir.  Apps are jailed to their sandbox.
      Capabilities: "fs.read" (bit 26), "fs.write" (bit 27).
      Complements AKIRA_WASM_STORAGE which provides the simpler surface.

config AKIRA_WASM_FS_MAX_FDS
    int "Maximum simultaneous open FS file descriptors"
    default 8
    range 2 32
    depends on AKIRA_WASM_FS
    help
      Global limit on open file descriptors for the FS API (independent of
      AKIRA_WASM_STORAGE_MAX_FDS).

config AKIRA_WASM_CRYPTO
    bool "Export cryptographic operations to WASM"
    default n
    depends on AKIRA_WASM_API
    select TINYCRYPT
    select TINYCRYPT_SHA256
    select TINYCRYPT_AES
    select TINYCRYPT_CBC_MODE
    select TINYCRYPT_HMAC
    help
      Expose SHA-256, AES-256-CBC, HMAC-SHA256 and random_bytes to WASM.
      Capability: "crypto" (bit 28).
      Key material is zeroed in memory after each operation.

config AKIRA_WASM_CRYPTO_MAX_INPUT
    int "Maximum crypto input size (bytes)"
    default 65536
    range 256 131072
    depends on AKIRA_WASM_CRYPTO
    help
      Maximum size of any single crypto operation input buffer.
      Operations exceeding this limit return -EMSGSIZE.

config AKIRA_WASM_RTC
    bool "Export real-time clock API to WASM"
    default n
    depends on AKIRA_WASM_API
    help
      Expose rtc_get_unix_time / rtc_get_uptime_ms / rtc_set_unix_time /
      rtc_set_alarm / rtc_alarm_fired to WASM.
      Falls back to k_uptime_get() when no RTC hardware is present.
      Capabilities: "rtc.read" (bit 29), "rtc.write" (bit 30).

config AKIRA_TELEMETRY
    bool "Structured JSON telemetry sink"
    default n
    help
      Emit structured JSON event lines via the Zephyr log backend (UART/RTT).
      When disabled all akira_telemetry_*() calls compile to empty inlines.

config AKIRA_PANIC
    bool "Panic handler with crash record storage"
    default n
    depends on NVS
    help
      Hooks k_sys_fatal_error_handler() to write a crash record (uptime,
      reason, fault address, last app name) to an NVS partition.  On next
      boot the record is logged at ERR level and erased.

endmenu

menu "Akira Settings"

config AKIRA_SETTINGS
    bool "Enable Akira Settings Manager"
    default y

config AKIRA_SETTINGS_MAX_KEYS
    int "Maximum number of keys"
    default 100
    range 1 500
    help
      Maximum number of key-value pairs that can be stored.
      Each key entry uses approximately 256 bytes in registry.

config AKIRA_SETTINGS_MAX_VALUE_LEN
    int "Maximum value length (bytes)"
    default 64
    range 32 256
    help
      Maximum length of a single value in bytes.
      This affects memory allocation for temporary buffers.

config AKIRA_SETTINGS_MAX_KEY_LEN
    int "Maximum key length (bytes)"
    default 32
    range 8 256
    help
      Maximum length of a single value in bytes.
      This affects memory allocation for temporary buffers.

choice AKIRA_SETTINGS_STORAGE_TYPE
    prompt "Default storage type"
    default AKIRA_SETTINGS_STORAGE_TYPE_FLASH
    help
      Select the default storage backend.

config AKIRA_SETTINGS_STORAGE_TYPE_FLASH
    bool "Flash (NVS)"
    help
      Store settings in internal flash memory using NVS.

config AKIRA_SETTINGS_STORAGE_TYPE_SD
    bool "SD Card"
    help
      Store settings on SD card (if available).

config AKIRA_SETTINGS_STORAGE_TYPE_AUTO
    bool "Auto (Flash)"
    help
      Automatically select storage: prefer Flash, fallback to SD.

endchoice

config AKIRA_SETTINGS_ENCRYPTION
    bool "Enable transparent encryption"
    default n
    depends on MBEDTLS_BUILTIN 
    select ENTROPY_GENERATOR
    select BASE64
    help
      Transparently encrypt all settings data using AES-256-GCM.
      Provides confidentiality and integrity protection.
      Uses ESP32 hardware AES acceleration for fast encryption.
      
      All devices must use the same encryption key for SD card portability.
      Data format: [2B magic][12B IV][encrypted data][16B auth tag]

if AKIRA_SETTINGS_ENCRYPTION

config AKIRA_SETTINGS_ENCRYPTION_KEY_HEX
    string "Encryption key (64 hex characters for AES-256)"
    default "c3c3a4e60f1991e85d7796890710e99338a4c5ac93bffc5c03dcf662bfcf9dee"
    help
      AES-256 encryption key in hexadecimal format (64 hex chars = 32 bytes).
      
      IMPORTANT: 
      - All devices must use the SAME key for SD card portability

config AKIRA_SETTINGS_ENCRYPTION_HW_ACCEL
    bool "Use hardware AES acceleration"
    default y if SOC_ESP32 || SOC_SERIES_ESP32S3
    default n
    select MBEDTLS_HARDWARE_ACCELERATION if SOC_ESP32 || SOC_SERIES_ESP32S3
    help
      Enable hardware AES acceleration for faster encryption/decryption.
      
      Supported platforms:
      - ESP32, ESP32-S3, ESP32-C3 (xtensa-esp32-aes)
      - STM32F4/F7/H7 (CRYP/HASH)
      - nRF52/53 with CryptoCell
      
      Hardware acceleration provides 5-10x speedup over software AES.

endif # AKIRA_SETTINGS_ENCRYPTION

endmenu

# ---------------------------------------------------------------------------
# SYS_INIT priorities — controls automatic subsystem startup order
# Lower value = runs first; all at APPLICATION init level
# ---------------------------------------------------------------------------
menu "AkiraOS init priorities"

config AKIRA_FS_INIT_PRIORITY
	int "Filesystem manager SYS_INIT priority"
	depends on FILE_SYSTEM
	default 40
	help
	  Automatic init priority for fs_manager.  Lower values run earlier.

config AKIRA_SETTINGS_INIT_PRIORITY
	int "Settings subsystem SYS_INIT priority"
	depends on AKIRA_SETTINGS
	default 50
	help
	  Must be greater than AKIRA_FS_INIT_PRIORITY when settings are
	  backed by the filesystem.

config AKIRA_USB_INIT_PRIORITY
	int "USB manager SYS_INIT priority"
	depends on AKIRA_USB
	default 60
	help
	  Automatic init priority for usb_manager.

config AKIRA_BT_INIT_PRIORITY
	int "Bluetooth manager SYS_INIT priority"
	depends on BT
	default 70
	help
	  Automatic init priority for bt_manager.

config AKIRA_WIFI_MANAGER_INIT_PRIORITY
    int "WiFi manager SYS_INIT priority"
    default 60
    depends on AKIRA_WIFI_MANAGER
    help
      Must be greater than AKIRA_SETTINGS_INIT_PRIORITY (default 50)
      so credentials are available when the manager initializes.

endmenu

