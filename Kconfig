menu "AkiraOS Configuration"

source "Kconfig.zephyr"

config AKIRA_OS
    bool "Enable AkiraOS features"
    default y
    help
      Enable AkiraOS specific features and drivers.
    select PRINTK

config AKIRA_LOG_LEVEL
    int "AkiraOS log level"
    default 3
    range 0 4
    help
      Set the log level for AkiraOS modules.
      0=OFF, 1=ERR, 2=WRN, 3=INF, 4=DBG


config AKIRA_TOUCH_XPT2046  
    bool "Enable XPT2046 touch controller"
    default n
    depends on INPUT && SPI
    help
      Enable XPT2046 touch screen controller.


config AKIRA_WASM_RUNTIME
    bool "Enable WebAssembly runtime (WAMR)"
    default n
    help
      Enable the unified Akira WAMR-based runtime. When enabled, Akira will
      build and link the wasm-micro-runtime (WAMR) and register native APIs.
      WAMR can use its builtin libc so this option is not constrained to a
      particular Zephyr libc choice; ensure sufficient heap is available for
      WAMRs global heap if using PSRAM or builtin heap.

config WAMR_AOT_SUPPORT
    bool "Enable WASM Ahead-of-Time (AOT) compilation support"
    default y if SOC_SERIES_ESP32S3 || BOARD_NATIVE_SIM
    # RISC-V targets (C6, H2, C3) have no PSRAM — AOT code must fit in SRAM.
    # Interpreter mode is sufficient and uses significantly less flash/RAM.
    default n if SOC_SERIES_ESP32C6 || SOC_ESP32H2
    default n
    depends on AKIRA_WASM_RUNTIME
    help
      Enable support for loading AOT-compiled WASM modules (.aot files).
      AOT modules provide faster execution but require LLVM-based toolchain
      for compilation. Adds approximately 40KB to firmware size.
      
      Disable this to save memory if you only need interpreter mode (.wasm).
      
      Recommended:
      - Enable for ESP32-S3 (XTENSA) and native_sim (powerful targets)
      - Disable for ARM Cortex-M targets (limited resources)

config AKIRA_RUNTIME_CUSTOM
    bool "Enable Akira unified custom runtime (Minimalist)"
    default y
    help
      Enable the unified Akira runtime implementation that is direct-to-WAMR.
      This is the preferred Minimalist Architecture path and registers a
      single native bridge for Display, Input, RF and Sensor APIs.

config WAMR_HEAP_SIZE
    int "WAMR heap warning threshold (bytes)"
    default 262144
    help
      Soft quota warning threshold for WAMR dynamic allocations.
      The runtime now uses Alloc_With_Allocator (PSRAM-first,
      SRAM fallback) instead of a static pool, so this value no
      longer reserves any RAM — it is only used for log warnings
      when total WAMR-managed memory exceeds this limit.

config AKIRA_WASM_APP_STACK_SIZE
    # WASM app thread stacks always live in SRAM (never PSRAM) to avoid
    # SPI0 bus contention on ESP32-S3 where PSRAM and internal flash share
    # the same bus: a direct flash read (e.g. from LittleFS fs_open) briefly
    # disables PSRAM cache access, crashing any thread whose stack is in PSRAM.
    # The WAMR interpreter operand stack lives in the WASM heap (PSRAM); the
    # Zephyr thread stack only carries the C native call chain (~4-8 KB).
    # 8 KB is sufficient for WAMR instantiate + fs I/O + native dispatch.
    # Constrained non-PSRAM boards (nRF54L15, etc.) can reduce to 4096.
    int "WASM app Zephyr thread stack size (bytes)"
    default 8192
    depends on AKIRA_WASM_RUNTIME
    help
      Stack size for the Zephyr k_thread that hosts each WASM app.
      Must reside in internal SRAM — do NOT use PSRAM for thread stacks
      on boards where PSRAM and flash share the SPI0 bus (ESP32-S3 family).
      The WASM heap and WASM binary can still use PSRAM.
      Total SRAM consumed: CONFIG_MAX_CONTAINERS * this value.
      Override per-board in boards/<board>.conf.

config AKIRA_WASM_APP_PRIORITY
    int "WASM app thread scheduling priority"
    # 14 matches Zephyr's default shell thread priority so WASM apps and the
    # shell share the CPU fairly (same-priority round-robin).  A value < 14
    # (e.g. the old default of 10) made WASM apps higher priority than the
    # shell, allowing a tight-looping app (e.g. logic_analyzer at 100 us/sample)
    # to permanently preempt the shell thread and lock out the console.
    default 14
    depends on AKIRA_WASM_RUNTIME
    help
      Preemptive thread priority for WASM app threads.
      Lower value = higher priority in Zephyr scheduling.
      Default 14 places WASM apps at the same level as the Zephyr shell thread
      so neither can starve the other.  Increase (lower priority) if system
      responsiveness under heavy WASM load is more important than app frame
      rate.  Decrease (higher priority) only if an app needs real-time
      scheduling and you accept potential shell unresponsiveness.

config MAX_CONTAINERS
    int "Maximum number of concurrently loaded WASM containers"
    default 8
    help
      Maximum number of WASM instances that can be loaded concurrently.
      Boards with more PSRAM can increase this value (CONFIG_MAX_CONTAINERS).

config AKIRA_DISPLAY
    bool "Enable Akira display support"
    default y if DISPLAY
    help
      Enable Akira display primitives and native WASM display exports.
      When disabled all display_* native calls return -ENOTSUP.

config AKIRA_WIFI
    bool "Enable Akira WiFi support"
    default y if WIFI
    help
      Enable Akira WiFi connectivity APIs.

config AKIRA_WIFI_MANAGER
    bool "Enable Akira WiFi Manager"
    default y
    depends on AKIRA_WIFI && WIFI && AKIRA_SETTINGS
    help
      Centralized WiFi lifecycle manager. Provides connect/disconnect,
      credential updates via the settings API, polling stats (RSSI,
      channel, time connected, tx/rx bytes), and an event callback.
      Does not auto-connect on boot — call wifi_manager_connect() explicitly.

config AKIRA_WIFI_MANAGER_MAX_CBS
    int "Maximum number of WiFi manager event callbacks"
    default 4
    range 1 16
    depends on AKIRA_WIFI_MANAGER
    help
      Size of the static callback table. Each slot is a function pointer
      plus a user_data pointer. 4 covers: shell, OS shell, cloud client,
      WASM bridge.

config AKIRA_TERMINAL_MODE
    bool "Enable hacker terminal mode"  
    default n
    depends on SHELL && NETWORKING
    help
      Enable cyberpunk hacker terminal with network tools.

config AKIRA_SELFTEST
    bool "Enable Akira self-test (native_sim)"
    default n
    depends on NATIVE_BUILD || CONFIG_BOARD_NATIVE_SIM
    help
      Enable a small self-test that installs a dummy WASM and verifies install/start on native_sim.
config AKIRA_CYBERPUNK_THEME
    bool "Enable cyberpunk UI theme"
    default n
    depends on LVGL
    help
      Enable cyberpunk-style user interface theme.

