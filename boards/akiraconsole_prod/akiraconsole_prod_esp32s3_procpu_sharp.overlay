/*
 * Sharp LS027B7DH01 Memory LCD overlay for AkiraConsole Production ESP32-S3.
 *
 * Applied automatically by CMakeLists.txt when CONFIG_AKIRA_SHARP_DISPLAY=y
 * is set in boards/akiraconsole_prod_esp32s3_procpu.conf.
 *
 * Hardware (Sharp LS027B7DH01 400x240 Memory LCD on J4):
 *   SCS  = GPIO10 = SPI2 cs-gpios[1] (ACTIVE_HIGH — Sharp polarity)
 *   MOSI = shared SPI2 (no MISO used)
 *   EXTCOMIN → not used (EXTMODE=LOW, COM inversion via serial command)
 *   DISP → pulled to +3.3V via R85 (10kΩ); not MCU-controlled
 *   VDD/VDDA → +5V via LM2750 charge pump (U19)
 */

#include <zephyr/dt-bindings/gpio/gpio.h>

/* Override chosen display */
/ {
	chosen {
		zephyr,display = &ls027b7dh01;
	};
};

/*
 * Disable the ST7789V/MIPI-DBI nodes — Sharp shares SPI2 but the
 * MIPI-DBI parent must not claim the bus.
 */
&mipi_dbi_prod {
	status = "disabled";
};

/* Enable Sharp node and override cs-gpios[1] to ACTIVE_HIGH.
 *
 * TCA6408 (I2C GPIO expander) is non-functional on this board.
 * LR1121 (CONFIG_AKIRA_LR1121=n) and CC1121 (CONFIG_AKIRA_CC1121=n) are
 * both disabled, so their chip-selects (cs-gpios[0] and cs-gpios[3]) are
 * redirected to GPIO39 and GPIO40, which are expansion-connector (J5) pins
 * with no active circuits attached.
 *
 * NOTE: GPIO33–GPIO37 are PSRAM-internal pins on the WROOM-1-N16R8 module
 * and must never be used as user GPIOs — they would crash the system
 * immediately by corrupting the OPI-PSRAM bus.
 */
&spi2 {
        cs-gpios =
                <&gpio1 7 GPIO_ACTIVE_LOW>,     /* [0] LR_CS  → GPIO39 (J5 expansion, LR1121 disabled) */
                <&gpio0 10 GPIO_ACTIVE_HIGH>,   /* [1] SCS    → GPIO10 Sharp ACTIVE_HIGH               */
                <&gpio0 14 GPIO_ACTIVE_LOW>,    /* [2] SD_CS  → GPIO14                                */
                <&gpio1 8 GPIO_ACTIVE_LOW>;     /* [3] CC_CS  → GPIO40 (J5 expansion, CC1121 disabled) */
	status = "okay";
};

&ls027b7dh01 {
	spi-lsb-first;
	spi-max-frequency = <1000000>;
	status = "okay";
};
