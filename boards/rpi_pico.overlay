/*
 * Raspberry Pi Pico (RP2040) DTS overlay for AkiraOS
 * Board: rpi_pico
 *
 * The upstream rpi_pico board in Zephyr already defines:
 *   - GPIO (26 pins), SPI0/1, I2C0/1, ADC, PWM, USB
 * This overlay adds AkiraOS-specific storage partitioning only.
 */

/*
 * RP2040 has 2 MB external QSPI Flash (W25Q16JV on standard Pico).
 * Zephyr's default partition table from the board file leaves a
 * storage_partition at the end of flash.  We remap it into:
 *   32 KB NVS  — settings / key-value store
 *   96 KB LittleFS — WASM app storage
 */
&w25q16jv {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        /* Keep MCUBoot slot-0 at the start if MCUBoot is enabled.
         * Without MCUBoot this can be ignored — Zephyr loads from 0x10000000.
         */
        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 DT_SIZE_K(64)>;
            read-only;
        };

        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 DT_SIZE_K(1792)>;
        };

        akira_settings_nvs_partition: partition@1d0000 {
            label = "akira_settings_nvs";
            reg = <0x001d0000 DT_SIZE_K(32)>;
        };

        lfs1_partition: partition@1d8000 {
            label = "lfs_storage";
            reg = <0x001d8000 DT_SIZE_K(96)>;
        };
    };
};

/ {
    chosen {
        zephyr,settings-partition = &akira_settings_nvs_partition;
    };

    fstab {
        compatible = "zephyr,fstab";

        lfs1: lfs1 {
            compatible = "zephyr,fstab,littlefs";
            read-size = <1>;
            prog-size = <256>;
            cache-size = <256>;
            lookahead-size = <32>;
            block-cycles = <512>;
            partition = <&lfs1_partition>;
            mount-point = "/lfs";
        };
    };
};
