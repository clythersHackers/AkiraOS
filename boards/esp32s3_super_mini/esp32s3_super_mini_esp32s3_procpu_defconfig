# SoC Configuration
CONFIG_SOC_SERIES_ESP32S3=y
CONFIG_SOC_ESP32S3_PROCPU=y

# Flash Configuration
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Console Configuration - Using USB Serial JTAG
CONFIG_CONSOLE=y
CONFIG_SERIAL=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_ESP32_USB_SERIAL_JTAG=y

# Basic Peripherals
CONFIG_GPIO=y
CONFIG_CLOCK_CONTROL=y

# Pinctrl
CONFIG_PINCTRL=y
