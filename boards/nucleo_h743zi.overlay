/*
 * ST Nucleo-H743ZI DTS overlay for AkiraOS
 * Board: nucleo_h743zi
 *
 * The upstream nucleo_h743zi board in Zephyr already defines:
 *   - USART3 on PD8/PD9 (console), ETH, SPI1/2/4/5, I2C1/2/4,
 *     ADC1/3, TIM1/2/3/4/5, USB OTG FS, SDMMC1, QSPI
 *
 * This overlay adds AkiraOS-specific flash partitioning.
 * STM32H743ZI: 2 MB dual-bank flash (bank1: 0x08000000, bank2: 0x08100000)
 */

/*
 * Partition layout (bank 1 = 1 MB, bank 2 = 1 MB):
 *   Bank 1: MCUBoot (64 KB) + slot-0 (960 KB)
 *   Bank 2: slot-1 for DFU (960 KB) + NVS (32 KB) + LittleFS (64 KB)
 *
 * Note: Zephyr's STM32H7 flash driver handles dual-bank automatically.
 */
&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        /* Bank 1 */
        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 DT_SIZE_K(64)>;
            read-only;
        };

        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 DT_SIZE_K(960)>;
        };

        /* Bank 2 (offset relative to flash0 start = 0x00100000) */
        slot1_partition: partition@100000 {
            label = "image-1";
            reg = <0x00100000 DT_SIZE_K(960)>;
        };

        akira_settings_nvs_partition: partition@1f0000 {
            label = "akira_settings_nvs";
            reg = <0x001f0000 DT_SIZE_K(32)>;
        };

        lfs1_partition: partition@1f8000 {
            label = "lfs_storage";
            reg = <0x001f8000 DT_SIZE_K(32)>;
        };
    };
};

/ {
    chosen {
        zephyr,settings-partition = &akira_settings_nvs_partition;
    };

    fstab {
        compatible = "zephyr,fstab";

        lfs1: lfs1 {
            compatible = "zephyr,fstab,littlefs";
            read-size = <1>;
            prog-size = <32>;
            cache-size = <64>;
            lookahead-size = <32>;
            block-cycles = <10000>;
            partition = <&lfs1_partition>;
            mount-point = "/lfs";
        };
    };
};
